# Cinderella — environment configuration
# Copy to `.env` and fill in real values. `.env` is git-ignored; never commit it.
# Use placeholders only in this file — never real IPs, secrets, or member data.

# --- SimpleX chat core (embedded in-process via the simplex-chat native SDK) ---
# There is NO separate daemon and NO network port: the bot embeds the Haskell
# chat core. The SimpleX core owns a local SQLite DB and a files folder, both on
# the same host as the bot.

# Display name of the bot's own SimpleX profile.
BOT_DISPLAY_NAME=Cinderella

# File prefix for the embedded SimpleX core DB (SQLite). The core creates
# <prefix>_chat.db and <prefix>_agent.db. This DB holds the bot's SimpleX
# identity/state — keep it under state/ (git-ignored) and lock down file perms.
SIMPLEX_DB_PREFIX=./state/simplex/cinderella

# Files folder the SimpleX core writes received (XFTP) files into, before
# Cinderella moves them into MEDIA_ROOT. Must be on the same host as the bot.
SIMPLEX_FILES_FOLDER=./state/files

# Optional: name of the group Cinderella archives. Used to scope/verify capture.
# Leave empty to capture from every group the bot is a member of.
GROUP_NAME=cinderella-test

# --- Cinderella media store ---
# Cinderella's own media tree (git-ignored). Captured files are moved here and
# the path is recorded in the database. Keep separate from SIMPLEX_FILES_FOLDER.
MEDIA_ROOT=./media

# --- PostgreSQL (the archive DB — separate from the SimpleX core's SQLite DB) ---
# Canonical connection string. Do not hardcode credentials in source.
DATABASE_URL=postgres://cinderella:CHANGEME@127.0.0.1:5432/cinderella

# --- Admin console (A3) ---
# The admin server binds to 127.0.0.1:ADMIN_PORT — nginx terminates TLS and
# proxies to it. Never expose this port directly.
ADMIN_PORT=8787

# Single operator account. Generate the Argon2id hash with:
#   npm run hash-password
# Quote the hash — it contains $ characters. Never store the plain password.
ADMIN_USERNAME=operator
ADMIN_PASSWORD_HASH='$argon2id$CHANGEME'

# Secret for signing session cookies. At least 32 random characters, e.g.:
#   openssl rand -hex 32
SESSION_SECRET=CHANGEME_at_least_32_random_characters_here

# Public origin of the admin console. Also the WebAuthn Relying Party: the RP ID
# (registrable domain) and expected origin derive from this, so it must be the
# real https:// admin hostname in production (WebAuthn needs a secure context and
# a domain-based RP ID — not a bare IP or plain HTTP).
PUBLIC_ORIGIN=https://cinderella.example.org

# Optional WebAuthn overrides (normally derived from PUBLIC_ORIGIN):
#   WEBAUTHN_RP_ID=cinderella.example.org
#   WEBAUTHN_ORIGIN=https://cinderella.example.org
#   WEBAUTHN_RP_NAME=Cinderella Admin

# --- Runtime ---
# Log verbosity: error | warn | info | debug
LOG_LEVEL=info

# Dependencies
node_modules/

# Build output
dist/

# Environment / secrets — never commit
.env
.env.local
.env.*.local

# Cinderella runtime data (never commit member data or media)
media/
state/

# Operator-supplied avatar image at the repo root (applied via `npm run avatar`).
# Root-anchored so it does NOT match source files like src/bot/avatar.ts.
/avatar.jpg
/avatar.jpeg
/avatar.png
/avatar.webp

# Generated front-end assets (built by `npm run assets`)
public/

# Logs
*.log
npm-debug.log*

# Editor / OS cruft
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

{
  "name": "cinderella",
  "version": "0.0.1-alpha",
  "private": true,
  "description": "Consent-based SimpleX-group-to-web archive bot.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "connect": "tsx src/bot/connect.ts",
    "avatar": "tsx src/bot/set-avatar.ts",
    "build": "tsc --build && npm run assets",
    "assets": "tailwindcss -i assets/app.css -o public/assets/app.css --minify && node scripts/copy-assets.mjs",
    "hash-password": "tsx scripts/hash-password.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "migrate": "tsx src/db/migrate.ts",
    "verify:db": "tsx scripts/verify-db.ts",
    "verify:consent": "tsx scripts/verify-consent.ts",
    "verify:admin": "tsx scripts/verify-admin.ts",
    "verify:admin-views": "tsx scripts/verify-admin-views.ts",
    "verify:security": "tsx scripts/verify-security.ts",
    "verify:public": "tsx scripts/verify-public.ts",
    "verify:site": "tsx scripts/verify-site.ts",
    "verify:interaction": "tsx scripts/verify-interaction.ts",
    "verify:price": "tsx scripts/verify-price.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.1.2",
    "@fastify/formbody": "^8.0.2",
    "@fastify/static": "^10.1.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.2",
    "@simplex-chat/types": "^0.8.0",
    "argon2": "^0.44.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.10.0",
    "lucide-static": "^1.24.0",
    "otplib": "^12.0.1",
    "pg": "^8.13.1",
    "qrcode": "^1.5.4",
    "sharp": "^0.33.5",
    "simplex-chat": "^6.5.4"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "@eslint/js": "^9.17.0",
    "@tailwindcss/cli": "^4.3.3",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "@types/qrcode": "^1.5.6",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "htmx.org": "^2.0.10",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.3.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0"
  }
}

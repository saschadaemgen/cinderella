{
  "name": "cinderella",
  "version": "0.1.0",
  "private": true,
  "description": "Consent-based SimpleX-group-to-web archive bot.",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "connect": "tsx src/bot/connect.ts",
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "migrate": "tsx src/db/migrate.ts",
    "verify:db": "tsx scripts/verify-db.ts",
    "verify:consent": "tsx scripts/verify-consent.ts"
  },
  "dependencies": {
    "@simplex-chat/types": "^0.8.0",
    "dotenv": "^16.4.7",
    "pg": "^8.13.1",
    "simplex-chat": "^6.5.4"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0"
  }
}
